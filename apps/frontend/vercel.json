{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "npm run vercel-build",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/uploads/:path*", "destination": "/api" }
  ]
}
