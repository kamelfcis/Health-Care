# Copy into Vercel → Environment Variables (Production + Preview for preview deploys)

# Recommended (one variable — works for axios + rewrites if you use relative /api):
NEXT_PUBLIC_API_BASE_URL=https://your-backend-project.vercel.app/api

# Optional: explicit rewrite origin (only if you use NEXT_PUBLIC_API_BASE_URL=/api)
# BACKEND_API_ORIGIN=https://your-backend-project.vercel.app
