# Vercel → Environment Variables (frontend project; Root Directory = apps/frontend)

# Server-only: powers the built-in /api proxy (see src/app/api/[[...path]]/route.ts)
BACKEND_PROXY_ORIGIN=https://your-backend-project.vercel.app

# Client axios base (same-origin proxy)
NEXT_PUBLIC_API_BASE_URL=/api

# Optional: legacy rewrite helper in next.config.mjs
# BACKEND_API_ORIGIN=https://your-backend-project.vercel.app
