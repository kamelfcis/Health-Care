# Vercel → Environment Variables (frontend project; Root Directory = apps/frontend)

# Required on Vercel (inlined at build — most reliable for the /api proxy route):
NEXT_PUBLIC_BACKEND_ORIGIN=https://your-backend-project.vercel.app

# Client axios base (same-origin → proxy → backend)
NEXT_PUBLIC_API_BASE_URL=/api

# Optional (server-only; also supported by proxy)
# BACKEND_PROXY_ORIGIN=https://your-backend-project.vercel.app
# BACKEND_API_ORIGIN=https://your-backend-project.vercel.app
