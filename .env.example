NODE_ENV=production
PORT=5000
# Production / VPS: use PostgreSQL (Prisma provider is postgresql)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/HealthCareDB?schema=public"
# Local demo (optional): SQLite — path relative to backend/ when running the API from backend
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/HealthCareDB?schema=public"
JWT_ACCESS_SECRET="replace_with_long_random_secret"
JWT_REFRESH_SECRET="replace_with_long_random_secret"
JWT_ACCESS_EXPIRES_IN="never"
JWT_REFRESH_EXPIRES_IN="never"
CORS_ORIGIN="http://95.216.63.81:3001,http://localhost:3001,http://127.0.0.1:3001,https://your-domain.com"
NEXT_PUBLIC_API_BASE_URL="http://95.216.63.81:5000/api"

# Vercel / production: set DATABASE_URL to your PostgreSQL connection string (same as VPS).
# Optional SQLite demo on Vercel: DATABASE_URL="file:./prisma/prisma/dev.db" (bundled demo DB only).
# NEXT_PUBLIC_API_BASE_URL on unified deploy: "/api"
