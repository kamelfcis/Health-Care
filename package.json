{
  "name": "healthcare-crm",
  "version": "1.0.0",
  "description": "Multi-clinic healthcare CRM SaaS monorepo",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "dev:mobile": "flutter run --project-dir \"apps/mobile\" --flavor dev -t lib/main_dev.dart",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "build:mobile:apk": "flutter build apk --project-dir \"apps/mobile\" --flavor production -t lib/main_production.dart",
    "build:mobile:ios": "flutter build ios --project-dir \"apps/mobile\" --flavor production -t lib/main_production.dart",
    "start": "npm run start --workspace backend",
    "lint": "npm run lint --workspace backend && npm run lint --workspace frontend",
    "db:migrate": "npm run db:migrate --workspace backend",
    "db:seed": "npm run db:seed --workspace backend"
  },
  "workspaces": [
    "apps/*",
    "backend"
  ],
  "keywords": [
    "healthcare",
    "crm",
    "saas",
    "monorepo"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "strip-bom": "^5.0.0"
  }
}
