# Copy to backend/.env or set in Vercel → Environment Variables
NODE_ENV=production
PORT=5000

# SQLite (local / Vercel demo — ephemeral on serverless) or Postgres in production
DATABASE_URL="file:./prisma/prisma/dev.db"

JWT_ACCESS_SECRET="change-me-min-16-chars-long-secret"
JWT_REFRESH_SECRET="change-me-min-16-chars-different-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated; must include your frontend origin(s)
CORS_ORIGIN=http://localhost:3000,https://your-frontend.vercel.app
